---
import { categories, commands, tagCloud } from "../data/commands";
import "../styles/global.css";

const categoryIds = new Map(categories.map((category) => [category, category.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "")]));

const typedReplies: Record<string, { resp2: string; resp3: string }> = {
  PING: {
    resp2: "simple<PONG> | bulk<message>",
    resp3: "simple<PONG> | blob<message>"
  },
  HELLO: {
    resp2: "[bulk field, reply value, ...]",
    resp3: "Map<simple field, reply value>"
  },
  AUTH: {
    resp2: "simple<OK> | error",
    resp3: "simple<OK> | error"
  },
  SELECT: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  CLIENT: {
    resp2: "simple | int | bulk | [reply, ...]",
    resp3: "simple | int | blob | Map | Push | [reply, ...]"
  },
  QUIT: {
    resp2: "simple<OK> -> close",
    resp3: "simple<OK> -> close"
  },
  INFO: {
    resp2: "bulk<line-oriented text>",
    resp3: "blob<line-oriented text>"
  },
  COMMAND: {
    resp2: "[[bulk name, int arity, [bulk flag, ...], ...], ...]",
    resp3: "Map | [[string name, int arity, [string flag, ...], ...], ...]"
  },
  EXISTS: {
    resp2: "int<count>",
    resp3: "int<count>"
  },
  DEL: {
    resp2: "int<removed>",
    resp3: "int<removed>"
  },
  UNLINK: {
    resp2: "int<unlinked>",
    resp3: "int<unlinked>"
  },
  TYPE: {
    resp2: "simple<none|string|list|set|zset|hash|stream>",
    resp3: "simple<none|string|list|set|zset|hash|stream>"
  },
  EXPIRE: {
    resp2: "int<0|1>",
    resp3: "int<0|1>"
  },
  PEXPIRE: {
    resp2: "int<0|1>",
    resp3: "int<0|1>"
  },
  TTL: {
    resp2: "int<seconds | -1 | -2>",
    resp3: "int<seconds | -1 | -2>"
  },
  PTTL: {
    resp2: "int<milliseconds | -1 | -2>",
    resp3: "int<milliseconds | -1 | -2>"
  },
  SCAN: {
    resp2: "[bulk cursor, [bulk key, ...]]",
    resp3: "[blob cursor, [blob key, ...]]"
  },
  KEYS: {
    resp2: "[bulk key, ...]",
    resp3: "[blob key, ...]"
  },
  RENAME: {
    resp2: "simple<OK> | error",
    resp3: "simple<OK> | error"
  },
  GET: {
    resp2: "bulk<value> | null-bulk",
    resp3: "blob<value> | null"
  },
  SET: {
    resp2: "simple<OK> | null-bulk | bulk<old-value>",
    resp3: "simple<OK> | null | blob<old-value>"
  },
  MGET: {
    resp2: "[bulk<value> | null-bulk, ...]",
    resp3: "[blob<value> | null, ...]"
  },
  MSET: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  INCR: {
    resp2: "int<new-value> | error",
    resp3: "int<new-value> | error"
  },
  DECR: {
    resp2: "int<new-value> | error",
    resp3: "int<new-value> | error"
  },
  APPEND: {
    resp2: "int<byte-length>",
    resp3: "int<byte-length>"
  },
  STRLEN: {
    resp2: "int<byte-length>",
    resp3: "int<byte-length>"
  },
  GETRANGE: {
    resp2: "bulk<slice>",
    resp3: "blob<slice>"
  },
  HGET: {
    resp2: "bulk<value> | null-bulk",
    resp3: "blob<value> | null"
  },
  HSET: {
    resp2: "int<new-fields>",
    resp3: "int<new-fields>"
  },
  HMGET: {
    resp2: "[bulk<value> | null-bulk, ...]",
    resp3: "[blob<value> | null, ...]"
  },
  HGETALL: {
    resp2: "[bulk field, bulk value, ...]",
    resp3: "Map<blob field, blob value>"
  },
  HDEL: {
    resp2: "int<removed-fields>",
    resp3: "int<removed-fields>"
  },
  HEXISTS: {
    resp2: "int<0|1>",
    resp3: "int<0|1>"
  },
  HSCAN: {
    resp2: "[bulk cursor, [bulk field, bulk value, ...]]",
    resp3: "[blob cursor, [blob field, blob value, ...]]"
  },
  LPUSH: {
    resp2: "int<list-length>",
    resp3: "int<list-length>"
  },
  RPUSH: {
    resp2: "int<list-length>",
    resp3: "int<list-length>"
  },
  LPOP: {
    resp2: "bulk<element> | null-bulk\n[count]: [bulk element, ...] | null-bulk",
    resp3: "blob<element> | null\n[count]: [blob element, ...] | null"
  },
  RPOP: {
    resp2: "bulk<element> | null-bulk\n[count]: [bulk element, ...] | null-bulk",
    resp3: "blob<element> | null\n[count]: [blob element, ...] | null"
  },
  LRANGE: {
    resp2: "[bulk element, ...]",
    resp3: "[blob element, ...]"
  },
  LLEN: {
    resp2: "int<list-length>",
    resp3: "int<list-length>"
  },
  BLPOP: {
    resp2: "[bulk key, bulk element] | null-array",
    resp3: "[blob key, blob element] | null"
  },
  BRPOP: {
    resp2: "[bulk key, bulk element] | null-array",
    resp3: "[blob key, blob element] | null"
  },
  SADD: {
    resp2: "int<new-members>",
    resp3: "int<new-members>"
  },
  SREM: {
    resp2: "int<removed-members>",
    resp3: "int<removed-members>"
  },
  SMEMBERS: {
    resp2: "[bulk member, ...]",
    resp3: "Set<blob member>"
  },
  SISMEMBER: {
    resp2: "int<0|1>",
    resp3: "int<0|1>"
  },
  SCARD: {
    resp2: "int<cardinality>",
    resp3: "int<cardinality>"
  },
  SSCAN: {
    resp2: "[bulk cursor, [bulk member, ...]]",
    resp3: "[blob cursor, [blob member, ...]]"
  },
  ZADD: {
    resp2: "int<added-or-changed>\n[INCR]: bulk<new-score>",
    resp3: "int<added-or-changed>\n[INCR]: double<new-score> | blob<new-score>"
  },
  ZRANGE: {
    resp2: "[bulk member, ...]\n[WITHSCORES]: [bulk member, bulk score, ...]",
    resp3: "[blob member, ...]\n[WITHSCORES]: [blob member, blob score, ...]"
  },
  ZREM: {
    resp2: "int<removed-members>",
    resp3: "int<removed-members>"
  },
  ZSCORE: {
    resp2: "bulk<score> | null-bulk",
    resp3: "double<score> | blob<score> | null"
  },
  ZRANK: {
    resp2: "int<rank> | null-bulk\n[WITHSCORE]: [int rank, bulk score]",
    resp3: "int<rank> | null\n[WITHSCORE]: [int rank, double score | blob score]"
  },
  ZCARD: {
    resp2: "int<cardinality>",
    resp3: "int<cardinality>"
  },
  ZSCAN: {
    resp2: "[bulk cursor, [bulk member, bulk score, ...]]",
    resp3: "[blob cursor, [blob member, blob score, ...]]"
  },
  XADD: {
    resp2: "bulk<entry-id> | null-bulk",
    resp3: "blob<entry-id> | null"
  },
  XRANGE: {
    resp2: "[[bulk id, [bulk field, bulk value, ...]], ...]",
    resp3: "[[blob id, Map<blob field, blob value>], ...]"
  },
  XREAD: {
    resp2: "[[bulk stream, [[bulk id, [bulk field, bulk value, ...]], ...]], ...] | null-array",
    resp3: "Map<blob stream, [[blob id, Map<blob field, blob value>], ...]> | null"
  },
  XGROUP: {
    resp2: "simple<OK> | int<count> | error",
    resp3: "simple<OK> | int<count> | error"
  },
  XREADGROUP: {
    resp2: "[[bulk stream, [[bulk id, [bulk field, bulk value, ...]], ...]], ...] | null-array",
    resp3: "Map<blob stream, [[blob id, Map<blob field, blob value>], ...]> | null"
  },
  XACK: {
    resp2: "int<acked>",
    resp3: "int<acked>"
  },
  SUBSCRIBE: {
    resp2: "[bulk subscribe, bulk channel, int count]\n[bulk message, bulk channel, bulk payload]",
    resp3: "Push<subscribe|message, blob channel, blob payload?>"
  },
  PSUBSCRIBE: {
    resp2: "[bulk psubscribe, bulk pattern, int count]\n[bulk pmessage, bulk pattern, bulk channel, bulk payload]",
    resp3: "Push<psubscribe|pmessage, blob pattern, blob channel?, blob payload?>"
  },
  PUBLISH: {
    resp2: "int<receivers>",
    resp3: "int<receivers>"
  },
  UNSUBSCRIBE: {
    resp2: "[bulk unsubscribe, bulk channel, int remaining]",
    resp3: "Push<unsubscribe, blob channel, int remaining>"
  },
  MULTI: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  EXEC: {
    resp2: "[reply, ...] | null-array",
    resp3: "[reply, ...] | null"
  },
  DISCARD: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  WATCH: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  UNWATCH: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  EVAL: {
    resp2: "bulk | int | [reply, ...] | null-bulk | simple | error",
    resp3: "blob | int | [reply, ...] | null | simple | error"
  },
  EVALSHA: {
    resp2: "bulk | int | [reply, ...] | null-bulk | simple | error<NOSCRIPT>",
    resp3: "blob | int | [reply, ...] | null | simple | error<NOSCRIPT>"
  },
  "SCRIPT LOAD": {
    resp2: "bulk<sha1>",
    resp3: "blob<sha1>"
  },
  "SCRIPT EXISTS": {
    resp2: "[int<0|1>, ...]",
    resp3: "[int<0|1>, ...]"
  },
  "CLUSTER SLOTS": {
    resp2: "[[int start, int end, [bulk host, int port, bulk id, ...], ...], ...]",
    resp3: "[[int start, int end, node, ...], ...] | Map"
  },
  "CLUSTER NODES": {
    resp2: "bulk<node-lines>",
    resp3: "blob<node-lines>"
  },
  ASKING: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  },
  READONLY: {
    resp2: "simple<OK>",
    resp3: "simple<OK>"
  }
};

const getTypedReply = (name: string, mode: "resp2" | "resp3", fallback: string) => typedReplies[name]?.[mode] ?? fallback;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A hacker-readable Redis protocol cheat sheet focused on command signatures, RESP2/RESP3 replies, and implementation edge cases."
    />
    <title>Redis Protocol Cheat Sheet</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="hero">
        <div class="hero-copy">
          <p class="eyebrow">redis://wire-reference</p>
          <h1>Redis Protocol Cheat Sheet</h1>
          <p class="dek">
            Command shapes, RESP replies, and edge conditions for developers building clients, proxies,
            protocol test suites or Redis-compatible servers.
          </p>
        </div>
        <aside class="status-panel" aria-label="Protocol status">
          <div class="status-row">
            <span>transport</span>
            <strong>TCP / RESP</strong>
          </div>
          <div class="status-row">
            <span>coverage</span>
            <strong>{commands.length} core commands</strong>
          </div>
          <div class="status-row">
            <span>mode</span>
            <strong data-mode-label>RESP2</strong>
          </div>
        </aside>
      </header>

      <nav class="control-deck" aria-label="Reference controls">
        <div class="search-wrap">
          <label for="command-search">Search</label>
          <input id="command-search" type="search" placeholder="GET, stream, nil, blocking..." autocomplete="off" />
        </div>

        <fieldset class="toggle-wrap" aria-label="RESP version">
          <legend>Protocol</legend>
          <label class="segmented">
            <input type="radio" name="resp-mode" value="resp2" checked />
            <span>RESP2</span>
          </label>
          <label class="segmented">
            <input type="radio" name="resp-mode" value="resp3" />
            <span>RESP3</span>
          </label>
        </fieldset>

        <div class="select-wrap">
          <label for="category-filter">Category</label>
          <select id="category-filter">
            <option value="all">All categories</option>
            {categories.map((category) => <option value={category}>{category}</option>)}
          </select>
        </div>
      </nav>

      <main>
        <section class="primer" aria-labelledby="primer-title">
          <div>
            <p class="section-kicker">RESP primer</p>
            <h2 id="primer-title">The minimum parser surface</h2>
          </div>
          <div class="primer-grid">
            <article>
              <h3>Requests</h3>
              <p>Clients send commands as arrays of bulk strings. The first element is the command name.</p>
              <code>*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n</code>
            </article>
            <article>
              <h3>RESP2 replies</h3>
              <p><code>+</code> simple string, <code>-</code> error, <code>:</code> integer, <code>$</code> bulk string, <code>*</code> array.</p>
              <p>Null is encoded as <code>$-1\r\n</code> or <code>*-1\r\n</code>, depending on context.</p>
            </article>
            <article>
              <h3>RESP3 replies</h3>
              <p>Adds native <code>_</code> null, <code>#</code> boolean, <code>,</code> double, <code>%</code> map, <code>~</code> set, and <code>&gt;</code> push.</p>
              <p>Use <code>HELLO 3</code> to switch a connection from RESP2 to RESP3.</p>
            </article>
          </div>
        </section>

        <section class="tag-strip" aria-label="Concern filters">
          <details class="notation-legend">
            <summary>reply notation</summary>
            <div class="legend-grid">
              <code>simple</code><span>RESP simple string</span>
              <code>bulk</code><span>RESP2 bulk string</span>
              <code>blob</code><span>RESP3 blob string</span>
              <code>int</code><span>RESP integer</span>
              <code>null-bulk</code><span>RESP2 <code>$-1</code></span>
              <code>null-array</code><span>RESP2 <code>*-1</code></span>
              <code>null</code><span>RESP3 <code>_</code></span>
              <code>reply</code><span>any nested RESP reply</span>
            </div>
          </details>
          <button class="tag active" type="button" data-tag="all">all</button>
          {tagCloud.map((tag) => <button class="tag" type="button" data-tag={tag}>{tag}</button>)}
        </section>

        <div class="results-line" aria-live="polite">
          <span id="result-count">{commands.length}</span> commands visible
        </div>

        {
          categories.map((category) => (
            <section class="command-section" id={categoryIds.get(category)} data-section={category}>
              <div class="section-heading">
                <p class="section-kicker">category</p>
                <h2>{category}</h2>
                <a href={`#${categoryIds.get(category)}`}>#</a>
              </div>
              <div class="command-grid">
                {commands
                  .filter((command) => command.category === category)
                  .map((command) => {
                    const resp2Shape = getTypedReply(command.name, "resp2", command.resp2);
                    const resp3Shape = getTypedReply(command.name, "resp3", command.resp3);
                    return (
                    <article
                      class="command-card"
                      data-command-card
                      data-name={command.name.toLowerCase()}
                      data-category={command.category}
                      data-tags={command.tags.join(" ")}
                      data-search={`${command.name} ${command.category} ${command.signature} ${command.params.join(" ")} ${command.notes.join(" ")} ${command.tags.join(" ")}`.toLowerCase()}
                    >
                      <header class="card-head">
                        <div>
                          <p class="command-category">{command.category}</p>
                          <h3>{command.name}</h3>
                        </div>
                        <div class="tag-bits">
                          {command.tags.slice(0, 3).map((tag) => (
                            <span>{tag}</span>
                          ))}
                        </div>
                      </header>

                      <div class="signature">
                        <span>$</span>
                        <code>{command.signature}</code>
                      </div>

                      <div class="card-columns">
                        <div>
                          <h4>Params</h4>
                          <ul>
                            {command.params.map((param) => (
                              <li>{param}</li>
                            ))}
                          </ul>
                        </div>
                        <div>
                          <h4>Reply</h4>
                          <div class="reply-panel">
                            <pre class="reply-code" data-resp2-shape={resp2Shape} data-resp3-shape={resp3Shape}>{resp2Shape}</pre>
                            <p class="reply-summary" data-resp2-note={command.resp2} data-resp3-note={command.resp3}>{command.resp2}</p>
                          </div>
                        </div>
                      </div>

                      <div class="notes">
                        <h4>Implementation notes</h4>
                        <ul>
                          {command.notes.map((note) => (
                            <li>{note}</li>
                          ))}
                        </ul>
                      </div>
                    </article>
                    );
                  })}
              </div>
            </section>
          ))
        }
      </main>
    </div>

    <script>
      const searchInput = document.querySelector("#command-search");
      const categoryFilter = document.querySelector("#category-filter");
      const resultCount = document.querySelector("#result-count");
      const modeLabels = document.querySelectorAll("[data-mode-label]");
      const modeInputs = document.querySelectorAll("input[name='resp-mode']");
      const tagButtons = document.querySelectorAll("[data-tag]");
      const cards = Array.from(document.querySelectorAll("[data-command-card]"));
      const sections = Array.from(document.querySelectorAll("[data-section]"));
      let selectedTag = "all";

      function updateMode(mode) {
        const label = mode.toUpperCase();
        modeLabels.forEach((node) => {
          node.textContent = label;
        });
        document.querySelectorAll("[data-resp2-shape]").forEach((node) => {
          node.textContent = node.dataset[`${mode}Shape`] || "";
        });
        document.querySelectorAll("[data-resp2-note]").forEach((node) => {
          node.textContent = node.dataset[`${mode}Note`] || "";
        });
        document.documentElement.dataset.respMode = mode;
      }

      function applyFilters() {
        const query = searchInput.value.trim().toLowerCase();
        const category = categoryFilter.value;
        let visible = 0;

        cards.forEach((card) => {
          const matchesQuery = !query || card.dataset.search.includes(query);
          const matchesCategory = category === "all" || card.dataset.category === category;
          const tags = card.dataset.tags.split(" ");
          const matchesTag = selectedTag === "all" || tags.includes(selectedTag);
          const show = matchesQuery && matchesCategory && matchesTag;
          card.hidden = !show;
          if (show) visible += 1;
        });

        sections.forEach((section) => {
          const visibleCards = section.querySelectorAll("[data-command-card]:not([hidden])").length;
          section.hidden = visibleCards === 0;
        });

        resultCount.textContent = String(visible);
      }

      modeInputs.forEach((input) => {
        input.addEventListener("change", () => updateMode(input.value));
      });

      tagButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectedTag = button.dataset.tag;
          tagButtons.forEach((tag) => tag.classList.toggle("active", tag === button));
          applyFilters();
        });
      });

      searchInput.addEventListener("input", applyFilters);
      categoryFilter.addEventListener("change", applyFilters);
      updateMode("resp2");
      applyFilters();
    </script>
  </body>
</html>
