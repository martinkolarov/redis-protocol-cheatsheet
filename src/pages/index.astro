const getTypedReply = (name: string, mode: "resp2" | "resp3", fallback: string) => typedReplies[name]?.[mode] ?? fallback;

type ReplyInspector = {
  tree: string;
  wire: string;
  decoded: string;
};

type ReplyInspectorSet = {
  resp2: ReplyInspector;
  resp3: ReplyInspector;
};

const simpleReply = (shape: string, summary: string, protocol: "RESP2" | "RESP3"): ReplyInspector => {
  const wire = shape.includes("int")
    ? ":1\\r\\n"
    : shape.includes("null") && protocol === "RESP3"
      ? "_\\r\\n"
      : shape.includes("null")
        ? "$-1\\r\\n"
        : shape.includes("Map")
          ? "%1\\r\\n+field\\r\\n$5\\r\\nvalue\\r\\n"
          : shape.includes("Set")
            ? "~2\\r\\n$3\\r\\none\\r\\n$3\\r\\ntwo\\r\\n"
            : shape.includes("[")
              ? "*2\\r\\n$3\\r\\none\\r\\n$3\\r\\ntwo\\r\\n"
              : shape.includes("bulk") || shape.includes("blob")
                ? "$5\\r\\nvalue\\r\\n"
                : "+OK\\r\\n";

  const decoded = shape.includes("int")
    ? "1"
    : shape.includes("null")
      ? "null"
      : shape.includes("Map")
        ? '{ "field": "value" }'
        : shape.includes("Set")
          ? 'Set { "one", "two" }'
          : shape.includes("[")
            ? '["one", "two"]'
            : shape.includes("bulk") || shape.includes("blob")
              ? '"value"'
              : '"OK"';

  return {
    tree: `reply\n├─ protocol: ${protocol}\n├─ shape: ${shape.replace(/\n/g, "\n│  or: ")}\n└─ meaning: ${summary}`,
    wire,
    decoded
  };
};

