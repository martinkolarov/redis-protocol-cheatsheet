  ZADD: {
    resp2: {
      tree: "integer | bulk string | null bulk\n├─ normal add/update: integer count\n├─ INCR success: new score as bulk string\n└─ INCR with failed NX/XX/GT/LT condition: null bulk, score unchanged",
      wire: ":1\\r\\n\n# INCR success\n$4\\r\\n10.5\\r\\n\n# INCR condition miss\n$-1\\r\\n",
      decoded: '{\n  "changed": 1,\n  "incrementedScore": "10.5",\n  "conditionMiss": null\n}'
    },
    resp3: {
      tree: "integer | double | null\n├─ normal add/update: integer count\n├─ INCR success: new score as double\n└─ INCR with failed NX/XX/GT/LT condition: null, score unchanged",
      wire: ":1\\r\\n\n# INCR success\n,10.5\\r\\n\n# INCR condition miss\n_\\r\\n",
      decoded: '{\n  "changed": 1,\n  "incrementedScore": 10.5,\n  "conditionMiss": null\n}'
    }
  },
  ZRANGE: {
    resp2: {
      tree: "array\n├─ member*: bulk string\n└─ WITHSCORES: alternating member bulk string, score bulk string",
      wire: "*4\\r\\n$5\\r\\nalice\\r\\n$4\\r\\n10.5\\r\\n$3\\r\\nbob\\r\\n$1\\r\\n8\\r\\n",
      decoded: '["alice", "10.5", "bob", "8"]'
    },
    resp3: {
      tree: "array\n├─ member*: blob string\n└─ WITHSCORES: alternating member blob string, score blob string",
      wire: "*4\\r\\n$5\\r\\nalice\\r\\n$4\\r\\n10.5\\r\\n$3\\r\\nbob\\r\\n$1\\r\\n8\\r\\n",
      decoded: '["alice", "10.5", "bob", "8"]'
    }
  },
  ZSCAN: {
    resp2: {
      tree: "array\n├─ cursor: bulk string\n└─ pairs: array\n   ├─ member: bulk string\n   ├─ score: bulk string\n   └─ repeated member/score pairs",
      wire: "*2\\r\\n$1\\r\\n0\\r\\n*4\\r\\n$5\\r\\nalice\\r\\n$4\\r\\n10.5\\r\\n$3\\r\\nbob\\r\\n$1\\r\\n8\\r\\n",
      decoded: '["0", ["alice", "10.5", "bob", "8"]]'
    },
    resp3: {
      tree: "array\n├─ cursor: blob string\n└─ pairs: array\n   ├─ member: blob string\n   ├─ score: blob string\n   └─ repeated member/score pairs",
      wire: "*2\\r\\n$1\\r\\n0\\r\\n*4\\r\\n$5\\r\\nalice\\r\\n$4\\r\\n10.5\\r\\n$3\\r\\nbob\\r\\n$1\\r\\n8\\r\\n",
      decoded: '["0", ["alice", "10.5", "bob", "8"]]'
    }
  },
  XRANGE: {
    resp2: {
      tree: "array\n└─ entry*\n   ├─ id: bulk string\n   └─ fields: array\n      ├─ field: bulk string\n      ├─ value: bulk string\n      └─ repeated field/value pairs",
      wire: "*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n*4\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n$3\\r\\nage\\r\\n$2\\r\\n42\\r\\n",
      decoded: '[["1700000000000-0", ["name", "alice", "age", "42"]]]'
    },
    resp3: {
      tree: "array\n└─ entry*\n   ├─ id: blob string\n   └─ fields: map\n      └─ field blob string => value blob string",
      wire: "*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n%2\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n$3\\r\\nage\\r\\n$2\\r\\n42\\r\\n",
      decoded: '[["1700000000000-0", { "name": "alice", "age": "42" }]]'
    }
  },
  XADD: {
    resp2: {
      tree: "bulk string | null bulk\n├─ success: entry ID as bulk string\n└─ NOMKSTREAM with missing stream: null bulk, no stream created",
      wire: "$15\\r\\n1700000000000-0\\r\\n\n# NOMKSTREAM missing stream\n$-1\\r\\n",
      decoded: '{\n  "success": "1700000000000-0",\n  "nomkstreamMissingStream": null\n}'
    },
    resp3: {
      tree: "blob string | null\n├─ success: entry ID as blob string\n└─ NOMKSTREAM with missing stream: null, no stream created",
      wire: "$15\\r\\n1700000000000-0\\r\\n\n# NOMKSTREAM missing stream\n_\\r\\n",
      decoded: '{\n  "success": "1700000000000-0",\n  "nomkstreamMissingStream": null\n}'
    }
  },
  XREAD: {
    resp2: {
      tree: "stream result array\n└─ served stream*\n   ├─ stream: bulk string\n   └─ entries: array of [id, fields]\n      ├─ id: bulk string\n      └─ fields: array of field/value bulk strings",
      wire: "*2\\r\\n*2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n*2\\r\\n$7\\r\\nwriters\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000001-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$3\\r\\nbob\\r\\n\n# non-blocking no data\n*-1\\r\\n\n# blocking data\n*1\\r\\n*2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000002-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n\n# blocking timeout\n*-1\\r\\n",
      decoded: '{\n  "nonBlockingData": [\n    ["mystream", [["1700000000000-0", ["name", "alice"]]]],\n    ["writers", [["1700000000001-0", ["name", "bob"]]]]\n  ],\n  "nonBlockingNoData": null,\n  "blockingData": [\n    ["mystream", [["1700000000002-0", ["name", "alice"]]]]\n  ],\n  "blockingTimeout": null\n}'
    },
    resp3: {
      tree: "stream result map\n└─ served stream key: blob string => entries array\n   └─ entry*\n      ├─ id: blob string\n      └─ fields: map of field blob string => value blob string",
      wire: "%2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n$7\\r\\nwriters\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000001-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$3\\r\\nbob\\r\\n\n# non-blocking no data\n_\\r\\n\n# blocking data\n%1\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000002-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n\n# blocking timeout\n_\\r\\n",
      decoded: '{\n  "nonBlockingData": {\n    "mystream": [["1700000000000-0", { "name": "alice" }]],\n    "writers": [["1700000000001-0", { "name": "bob" }]]\n  },\n  "nonBlockingNoData": null,\n  "blockingData": {\n    "mystream": [["1700000000002-0", { "name": "alice" }]]\n  },\n  "blockingTimeout": null\n}'
    }
  },
  XREADGROUP: {
    resp2: {
      tree: "stream result array\n└─ served stream*\n   ├─ stream: bulk string\n   └─ entries: array of [id, fields]\n      ├─ id: bulk string\n      └─ fields: array of field/value bulk strings",
      wire: "*2\\r\\n*2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n*2\\r\\n$7\\r\\nwriters\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000001-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$3\\r\\nbob\\r\\n\n# non-blocking no data\n*-1\\r\\n\n# blocking data\n*1\\r\\n*2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000002-0\\r\\n*2\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n\n# blocking timeout\n*-1\\r\\n",
      decoded: '{\n  "nonBlockingData": [\n    ["mystream", [["1700000000000-0", ["name", "alice"]]]],\n    ["writers", [["1700000000001-0", ["name", "bob"]]]]\n  ],\n  "nonBlockingNoData": null,\n  "blockingData": [\n    ["mystream", [["1700000000002-0", ["name", "alice"]]]]\n  ],\n  "blockingTimeout": null\n}'
    },
    resp3: {
      tree: "stream result map\n└─ served stream key: blob string => entries array\n   └─ entry*\n      ├─ id: blob string\n      └─ fields: map of field blob string => value blob string",
      wire: "%2\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000000-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n$7\\r\\nwriters\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000001-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$3\\r\\nbob\\r\\n\n# non-blocking no data\n_\\r\\n\n# blocking data\n%1\\r\\n$8\\r\\nmystream\\r\\n*1\\r\\n*2\\r\\n$15\\r\\n1700000000002-0\\r\\n%1\\r\\n$4\\r\\nname\\r\\n$5\\r\\nalice\\r\\n\n# blocking timeout\n_\\r\\n",
      decoded: '{\n  "nonBlockingData": {\n    "mystream": [["1700000000000-0", { "name": "alice" }]],\n    "writers": [["1700000000001-0", { "name": "bob" }]]\n  },\n  "nonBlockingNoData": null,\n  "blockingData": {\n    "mystream": [["1700000000002-0", { "name": "alice" }]]\n  },\n  "blockingTimeout": null\n}'
    }
  },
  SUBSCRIBE: {
    resp2: {
      tree: "array push-like message\n├─ kind: bulk string subscribe | message\n├─ channel: bulk string\n└─ count or payload: integer | bulk string",
      wire: "*3\\r\\n$9\\r\\nsubscribe\\r\\n$4\\r\\nnews\\r\\n:1\\r\\n\n*3\\r\\n$7\\r\\nmessage\\r\\n$4\\r\\nnews\\r\\n$5\\r\\nhello\\r\\n",
      decoded: '["subscribe", "news", 1]\n["message", "news", "hello"]'
    },
    resp3: {
      tree: "push\n├─ kind: blob string subscribe | message\n├─ channel: blob string\n└─ count or payload: integer | blob string",
      wire: ">3\\r\\n$9\\r\\nsubscribe\\r\\n$4\\r\\nnews\\r\\n:1\\r\\n\n>3\\r\\n$7\\r\\nmessage\\r\\n$4\\r\\nnews\\r\\n$5\\r\\nhello\\r\\n",
      decoded: 'push("subscribe", "news", 1)\npush("message", "news", "hello")'
    }
  },
  PSUBSCRIBE: {
    resp2: {
      tree: "array push-like message\n├─ kind: bulk string psubscribe | pmessage\n├─ pattern: bulk string\n├─ channel: bulk string when pmessage\n└─ count or payload: integer | bulk string",
      wire: "*3\\r\\n$10\\r\\npsubscribe\\r\\n$6\\r\\nnews.*\\r\\n:1\\r\\n\n*4\\r\\n$8\\r\\npmessage\\r\\n$6\\r\\nnews.*\\r\\n$9\\r\\nnews.east\\r\\n$5\\r\\nhello\\r\\n",
      decoded: '["psubscribe", "news.*", 1]\n["pmessage", "news.*", "news.east", "hello"]'
    },
    resp3: {
      tree: "push\n├─ kind: blob string psubscribe | pmessage\n├─ pattern: blob string\n├─ channel: blob string when pmessage\n└─ count or payload: integer | blob string",
      wire: ">3\\r\\n$10\\r\\npsubscribe\\r\\n$6\\r\\nnews.*\\r\\n:1\\r\\n\n>4\\r\\n$8\\r\\npmessage\\r\\n$6\\r\\nnews.*\\r\\n$9\\r\\nnews.east\\r\\n$5\\r\\nhello\\r\\n",
      decoded: 'push("psubscribe", "news.*", 1)\npush("pmessage", "news.*", "news.east", "hello")'
    }
  },
  EXEC: {
    resp2: {
      tree: "array | null array\n├─ reply[0]: nested reply from queued command\n├─ reply[1]: nested reply from queued command\n└─ null array when WATCH aborts",
      wire: "*2\\r\\n+OK\\r\\n:2\\r\\n\n# WATCH abort\n*-1\\r\\n",
      decoded: '{\n  "success": ["OK", 2],\n  "watchAbort": null\n}'
    },
    resp3: {
      tree: "array | null\n├─ reply[0]: nested reply from queued command\n├─ reply[1]: nested reply from queued command\n└─ null when WATCH aborts",
      wire: "*2\\r\\n+OK\\r\\n:2\\r\\n\n# WATCH abort\n_\\r\\n",
      decoded: '{\n  "success": ["OK", 2],\n  "watchAbort": null\n}'
    }
  },
  "CLUSTER SLOTS": {
    resp2: {
      tree: "array\n└─ slot range*\n   ├─ start slot: integer\n   ├─ end slot: integer\n   ├─ master: array [host bulk, port int, node id bulk, ...]\n   └─ replica*: array [host bulk, port int, node id bulk, ...]",
      wire: "*1\\r\\n*3\\r\\n:0\\r\\n:5460\\r\\n*3\\r\\n$9\\r\\n127.0.0.1\\r\\n:7000\\r\\n$40\\r\\n07c37dfeb2352e0b6f0...\\r\\n",
      decoded: '[[0, 5460, ["127.0.0.1", 7000, "07c37d..."]]]'
    },
    resp3: {
      tree: "array or map-like aggregate\n└─ slot range*\n   ├─ start slot: integer\n   ├─ end slot: integer\n   └─ node endpoint metadata",
      wire: "*1\\r\\n*3\\r\\n:0\\r\\n:5460\\r\\n*3\\r\\n$9\\r\\n127.0.0.1\\r\\n:7000\\r\\n$40\\r\\n07c37dfeb2352e0b6f0...\\r\\n",
      decoded: '[[0, 5460, ["127.0.0.1", 7000, "07c37d..."]]]'
    }
  }
};

const getReplyInspector = (name: string, resp2Shape: string, resp3Shape: string, resp2Summary: string, resp3Summary: string): ReplyInspectorSet =>
  replyInspectors[name] ?? {
