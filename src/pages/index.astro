const getTypedReply = (name: string, mode: "resp2" | "resp3", fallback: string) => typedReplies[name]?.[mode] ?? fallback;

type ReplyInspector = {
  tree: string;
  wire: string;
  decoded: string;
};

type ReplyInspectorSet = {
  resp2: ReplyInspector;
  resp3: ReplyInspector;
};

const simpleReply = (shape: string, _summary: string, protocol: "RESP2" | "RESP3"): ReplyInspector => {
  const stringType = protocol === "RESP2" ? "bulk string" : "blob string";
  const trimmedShape = shape.trim();
  const isMap = trimmedShape.startsWith("Map<") || trimmedShape === "Map";
  const isSet = trimmedShape.startsWith("Set<") || trimmedShape === "Set";
  const isArray = trimmedShape.startsWith("[") || trimmedShape.includes(" | [");
  const isNull = trimmedShape === "null" || trimmedShape.startsWith("null");
  const isInt = trimmedShape.startsWith("int<");
  const isBlob = trimmedShape.startsWith("blob<");
  const isBulk = trimmedShape.startsWith("bulk<");
  const simplePayload = trimmedShape.match(/simple<([^>]+)>/)?.[1] || "OK";
  const wire = isMap
    ? "%1\\r\\n+field\\r\\n$5\\r\\nvalue\\r\\n"
    : isSet
      ? "~2\\r\\n$3\\r\\none\\r\\n$3\\r\\ntwo\\r\\n"
      : isArray
        ? "*2\\r\\n$3\\r\\none\\r\\n$3\\r\\ntwo\\r\\n"
        : isInt
          ? ":1\\r\\n"
          : isNull && protocol === "RESP3"
      ? "_\\r\\n"
      : isNull
        ? "$-1\\r\\n"
              : isBulk || isBlob
                ? "$5\\r\\nvalue\\r\\n"
                : `+${simplePayload}\\r\\n`;

  const decoded = isMap
    ? '{ "field": "value" }'
    : isSet
      ? 'Set { "one", "two" }'
      : isArray
        ? '["one", "two"]'
        : isInt
          ? "1"
          : isNull
      ? "null"
            : isBulk || isBlob
              ? '"value"'
              : JSON.stringify(simplePayload);

  const tree = isMap
      ? `map\n└─ field: ${stringType}\n   └─ value: ${stringType}`
      : isSet
        ? `set\n└─ member*: ${stringType}`
        : isArray
          ? `array\n└─ element*: ${stringType}`
          : trimmedShape;

  return {
    tree,
    wire,
    decoded
  };
};

