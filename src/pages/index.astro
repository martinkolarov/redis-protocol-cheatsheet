    resp2: {
      tree: "array push-like message\n├─ kind: bulk string psubscribe | pmessage\n├─ pattern: bulk string\n├─ channel: bulk string when pmessage\n└─ count or payload: integer | bulk string",
      wire: "*3\\r\\n$10\\r\\npsubscribe\\r\\n$6\\r\\nnews.*\\r\\n:1\\r\\n\n*4\\r\\n$8\\r\\npmessage\\r\\n$6\\r\\nnews.*\\r\\n$9\\r\\nnews.east\\r\\n$5\\r\\nhello\\r\\n",
      decoded: '["psubscribe", "news.*", 1]\n["pmessage", "news.*", "news.east", "hello"]'
    },
    resp3: {
      tree: "push\n├─ kind: blob string psubscribe | pmessage\n├─ pattern: blob string\n├─ channel: blob string when pmessage\n└─ count or payload: integer | blob string",
      wire: ">3\\r\\n$10\\r\\npsubscribe\\r\\n$6\\r\\nnews.*\\r\\n:1\\r\\n\n>4\\r\\n$8\\r\\npmessage\\r\\n$6\\r\\nnews.*\\r\\n$9\\r\\nnews.east\\r\\n$5\\r\\nhello\\r\\n",
      decoded: 'push("psubscribe", "news.*", 1)\npush("pmessage", "news.*", "news.east", "hello")'
    }
  },
  EXEC: {
    resp2: {
      tree: "array | null array\n├─ reply[0]: nested reply from queued command\n├─ reply[1]: nested reply from queued command\n└─ null array when WATCH aborts",
      wire: "*2\\r\\n+OK\\r\\n:2\\r\\n\n# WATCH abort\n*-1\\r\\n",
      decoded: '{\n  "success": ["OK", 2],\n  "watchAbort": null\n}'
    },
    resp3: {
      tree: "array | null\n├─ reply[0]: nested reply from queued command\n├─ reply[1]: nested reply from queued command\n└─ null when WATCH aborts",
      wire: "*2\\r\\n+OK\\r\\n:2\\r\\n\n# WATCH abort\n_\\r\\n",
      decoded: '{\n  "success": ["OK", 2],\n  "watchAbort": null\n}'
    }
  },
  "CLUSTER SLOTS": {
    resp2: {
      tree: "array\n└─ slot range*\n   ├─ start slot: integer\n   ├─ end slot: integer\n   ├─ master: array [host bulk, port int, node id bulk, ...]\n   └─ replica*: array [host bulk, port int, node id bulk, ...]",
      wire: "*1\\r\\n*3\\r\\n:0\\r\\n:5460\\r\\n*3\\r\\n$9\\r\\n127.0.0.1\\r\\n:7000\\r\\n$40\\r\\n07c37dfeb2352e0b6f0...\\r\\n",
      decoded: '[[0, 5460, ["127.0.0.1", 7000, "07c37d..."]]]'
    },
    resp3: {
      tree: "array or map-like aggregate\n└─ slot range*\n   ├─ start slot: integer\n   ├─ end slot: integer\n   └─ node endpoint metadata",
      wire: "*1\\r\\n*3\\r\\n:0\\r\\n:5460\\r\\n*3\\r\\n$9\\r\\n127.0.0.1\\r\\n:7000\\r\\n$40\\r\\n07c37dfeb2352e0b6f0...\\r\\n",
      decoded: '[[0, 5460, ["127.0.0.1", 7000, "07c37d..."]]]'
    }
  }
};

const getReplyInspector = (name: string, resp2Shape: string, resp3Shape: string, resp2Summary: string, resp3Summary: string): ReplyInspectorSet =>
  replyInspectors[name] ?? {
    resp2: simpleReply(resp2Shape, resp2Summary, "RESP2"),
    resp3: simpleReply(resp3Shape, resp3Summary, "RESP3")
  };

const keyspaceCommands = new Set([
  "EXISTS",
  "DEL",
  "UNLINK",
  "TYPE",
  "EXPIRE",
  "PEXPIRE",
  "TTL",
  "PTTL",
  "RENAME",
  "GET",
  "SET",
  "MGET",
  "MSET",
  "INCR",
  "DECR",
  "APPEND",
  "STRLEN",
  "GETRANGE",
  "HGET",
  "HSET",
  "HMGET",
  "HGETALL",
  "HDEL",
  "HEXISTS",
  "HSCAN",
  "LPUSH",
  "RPUSH",
  "LPOP",
  "RPOP",
  "LRANGE",
  "LLEN",
  "BLPOP",
  "BRPOP",
  "SADD",
  "SREM",
  "SMEMBERS",
  "SISMEMBER",
  "SCARD",
  "SSCAN",
  "ZADD",
  "ZRANGE",
  "ZREM",
  "ZSCORE",
  "ZRANK",
  "ZCARD",
  "ZSCAN",
  "XADD",
  "XRANGE",
  "XREAD",
  "XGROUP",
  "XREADGROUP",
  "XACK"
]);

const writeCommands = new Set([
  "DEL",
  "UNLINK",
  "EXPIRE",
  "PEXPIRE",
  "RENAME",
  "SET",
  "MSET",
  "INCR",
  "DECR",
  "APPEND",
  "HSET",
  "HDEL",
  "LPUSH",
  "RPUSH",
  "LPOP",
  "RPOP",
  "BLPOP",
  "BRPOP",
  "SADD",
  "SREM",
  "ZADD",
  "ZREM",
  "XADD",
  "XGROUP",
  "XREADGROUP",
  "XACK",
  "PUBLISH",
  "EVAL",
  "EVALSHA",
  "SCRIPT LOAD"
]);

const typeCheckedCategories = new Set(["Strings", "Hashes", "Lists", "Sets", "Sorted Sets", "Streams"]);
const noGenericWrongType = new Set(["SET", "MGET", "MSET"]);

const numericArgNames = ["seconds", "milliseconds", "index", "cursor", "count", "start", "stop", "increment", "timeout", "score", "rank", "numkeys", "port", "slot"];

const commandErrorCases: Record<string, string[]> = {
  HELLO: ["Unsupported protover -> -NOPROTO unsupported protocol version.", "AUTH option failure -> -WRONGPASS invalid username-password pair or user disabled."],
  AUTH: ["Bad credentials -> -WRONGPASS invalid username-password pair or user disabled.", "AUTH when no password is configured -> -ERR AUTH <password> called without any password configured."],
  SELECT: ["Invalid DB index -> -ERR invalid DB index.", "Cluster mode DB other than 0 -> -ERR SELECT is not allowed in cluster mode."],
  CLIENT: ["Unknown subcommand or blocked operation -> -ERR with subcommand-specific text.", "CLIENT REPLY OFF/SKIP changes whether later errors are delivered to the client."],
  RENAME: ["Missing source key -> -ERR no such key."],
  SET: ["NX/XX condition miss is not an error; return null instead.", "Conflicting expiry or condition options -> -ERR syntax error.", "With GET, an existing non-string value -> -WRONGTYPE."],
  INCR: ["Value is not a base-10 signed 64-bit integer -> -ERR value is not an integer or out of range.", "Overflow -> -ERR increment or decrement would overflow."],
  DECR: ["Value is not a base-10 signed 64-bit integer -> -ERR value is not an integer or out of range.", "Overflow -> -ERR increment or decrement would overflow."],
  GETRANGE: ["Invalid range indexes -> -ERR value is not an integer or out of range."],
  BLPOP: ["Timeout is not an error; return null array/null when no element becomes available.", "Negative timeout -> -ERR timeout is negative."],
  BRPOP: ["Timeout is not an error; return null array/null when no element becomes available.", "Negative timeout -> -ERR timeout is negative."],
  ZADD: ["Invalid score -> -ERR value is not a valid float.", "Conflicting NX/XX/GT/LT options -> -ERR syntax error."],
  ZSCORE: ["Missing member/key is not an error; return null."],
  XADD: ["ID not greater than stream top item -> -ERR The ID specified in XADD is equal or smaller than the target stream top item.", "MAXLEN/MINID syntax or bad ID -> -ERR with stream-specific text."],
  XREAD: ["Timeout is not an error; return null array/null when BLOCK expires.", "Malformed stream ID or COUNT/BLOCK value -> -ERR with stream-specific text."],
  XGROUP: ["Missing stream/group/consumer state can produce -NOGROUP or -BUSYGROUP depending on subcommand.", "Bad stream ID -> -ERR with stream-specific text."],
  XREADGROUP: ["Unknown group or missing key group state -> -NOGROUP.", "Timeout is not an error; return null array/null when BLOCK expires."],
  XACK: ["Unknown group or missing key group state -> -NOGROUP."],
  SUBSCRIBE: ["In RESP2 subscribed mode, only a limited command set is accepted; other commands return -ERR.", "Malformed channel arguments -> -ERR wrong number of arguments."],
  PSUBSCRIBE: ["In RESP2 subscribed mode, only a limited command set is accepted; other commands return -ERR.", "Malformed pattern arguments -> -ERR wrong number of arguments."],
  PUBLISH: ["Invalid argument count -> -ERR wrong number of arguments."],
  MULTI: ["Nested MULTI -> -ERR MULTI calls can not be nested."],
  EXEC: ["Watched key changed -> null array/null, not an error.", "Queued command failure before EXEC -> -EXECABORT Transaction discarded because of previous errors."],
  DISCARD: ["Without MULTI -> -ERR DISCARD without MULTI."],
  WATCH: ["Inside MULTI -> -ERR WATCH inside MULTI is not allowed."],
  EVAL: ["Script runtime error -> -ERR Error running script.", "Wrong numkeys or undeclared cluster keys -> -ERR/-CROSSSLOT depending on mode."],
  EVALSHA: ["Unknown SHA1 -> -NOSCRIPT No matching script. Please use EVAL.", "Script runtime error -> -ERR Error running script."],
  "SCRIPT LOAD": ["Invalid Lua source -> -ERR Error compiling script."],
  "CLUSTER SLOTS": ["Cluster support disabled -> -ERR This instance has cluster support disabled."],
  "CLUSTER NODES": ["Cluster support disabled -> -ERR This instance has cluster support disabled."],
  ASKING: ["Cluster support disabled -> -ERR This instance has cluster support disabled."],
  READONLY: ["Cluster support disabled -> -ERR This instance has cluster support disabled."]
};

const hasNumericArgs = (command: { signature: string; params: string[] }) => {
  const text = `${command.signature} ${command.params.join(" ")}`.toLowerCase();
  return numericArgNames.some((name) => new RegExp(`\\b${name}\\b`).test(text));
};

const getErrorCases = (command: { name: string; category: string; signature: string; params: string[]; tags: string[] }) => {
  const cases = ["Bad arity or malformed options -> -ERR wrong number of arguments or -ERR syntax error."];

  if (typeCheckedCategories.has(command.category) && !noGenericWrongType.has(command.name)) {
    cases.push("Existing key with incompatible type -> -WRONGTYPE Operation against a key holding the wrong kind of value.");
  }

  if (hasNumericArgs(command)) {
    cases.push("Non-integer integer argument or out-of-range value -> -ERR value is not an integer or out of range.");
  }

  if (keyspaceCommands.has(command.name)) {
    cases.push("Cluster slot owner mismatch -> -MOVED; temporary migration target -> -ASK, then retry after ASKING.");
  }

  if (writeCommands.has(command.name)) {
    cases.push("Write attempted against a read-only replica or read-only script context -> -READONLY.");
  }

  return [...cases, ...(commandErrorCases[command.name] ?? [])];
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A hacker-readable Redis protocol cheat sheet focused on command signatures, RESP2/RESP3 replies, and implementation edge cases."
    />
    <meta name="build-id" content={buildId} />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="expires" content="0" />
    <title>Redis Protocol Cheat Sheet</title>
  </head>
  <body data-build-id={buildId} data-version-url={versionUrl}>
    <div class="page-shell">
      <header class="hero">
        <div class="hero-copy">
          <p class="eyebrow">redis://wire-reference</p>
          <h1>Redis Protocol Cheat Sheet</h1>
          <p class="dek">
            Command shapes, RESP replies, and edge conditions for developers building clients, proxies,
            protocol test suites or Redis-compatible servers.
          </p>
        </div>
        <aside class="status-panel" aria-label="Protocol status">
          <div class="status-row">
            <span>transport</span>
            <strong>TCP / RESP</strong>
          </div>
          <div class="status-row">
            <span>coverage</span>
            <strong>{commands.length} core commands</strong>
          </div>
          <div class="status-row">
            <span>mode</span>
            <strong data-mode-label>RESP2</strong>
          </div>
          <div class="status-row">
            <span>build</span>
            <strong>{shortBuildId}</strong>
          </div>
        </aside>
      </header>

      <main>
        <section class="primer" aria-labelledby="primer-title">
          <div>
            <p class="section-kicker">RESP primer</p>
            <h2 id="primer-title">The minimum parser surface</h2>
          </div>
          <div class="primer-grid">
            <article>
              <h3>Requests</h3>
              <p>Clients send commands as arrays of bulk strings. The first element is the command name.</p>
              <code>*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n</code>
            </article>
            <article>
              <h3>RESP2 replies</h3>
              <p><code>+</code> simple string, <code>-</code> error, <code>:</code> integer, <code>$</code> bulk string, <code>*</code> array.</p>
              <p>Null is encoded as <code>$-1\r\n</code> or <code>*-1\r\n</code>, depending on context.</p>
            </article>
            <article>
              <h3>RESP3 replies</h3>
          <p>Adds native <code>_</code> null, <code>#</code> boolean, <code>,</code> double, <code>%</code> map, <code>~</code> set, and <code>&gt;</code> push.</p>
          <p>Use <code>HELLO 3</code> to switch a connection from RESP2 to RESP3.</p>
        </article>
        <article>
          <h3>Errors</h3>
          <p>Errors are RESP error replies: <code>-PREFIX message\r\n</code>. The prefix is the stable part clients should classify.</p>
          <p>Common prefixes include <code>ERR</code>, <code>WRONGTYPE</code>, <code>NOAUTH</code>, <code>NOSCRIPT</code>, <code>MOVED</code>, <code>ASK</code>, and <code>READONLY</code>.</p>
        </article>
      </div>
    </section>

        <section class="tag-strip" aria-label="Concern filters">
          <details class="notation-legend">
            <summary>reply notation</summary>
            <div class="legend-grid">
              <code>simple</code><span>RESP simple string</span>
              <code>bulk</code><span>RESP2 bulk string</span>
              <code>blob</code><span>RESP3 blob string</span>
              <code>int</code><span>RESP integer</span>
              <code>null-bulk</code><span>RESP2 <code>$-1</code></span>
              <code>null-array</code><span>RESP2 <code>*-1</code></span>
              <code>null</code><span>RESP3 <code>_</code></span>
              <code>error&lt;PREFIX&gt;</code><span>RESP error; classify by prefix</span>
              <code>reply</code><span>any nested RESP reply</span>
            </div>
          </details>
          <button class="tag active" type="button" data-tag="all">all</button>
          {tagCloud.map((tag) => <button class="tag" type="button" data-tag={tag}>{tag}</button>)}
        </section>

        <nav class="control-deck" aria-label="Reference controls">
          <div class="search-wrap">
            <label for="command-search">Search</label>
            <input id="command-search" type="search" placeholder="GET, stream, nil, blocking..." autocomplete="off" />
          </div>

          <fieldset class="toggle-wrap" aria-label="RESP version">
            <legend>Protocol</legend>
            <label class="segmented">
              <input type="radio" name="resp-mode" value="resp2" checked />
              <span>RESP2</span>
            </label>
            <label class="segmented">
              <input type="radio" name="resp-mode" value="resp3" />
              <span>RESP3</span>
            </label>
          </fieldset>

          <div class="select-wrap">
            <label for="category-filter">Category</label>
            <select id="category-filter">
              <option value="all">All categories</option>
              {categories.map((category) => <option value={category}>{category}</option>)}
            </select>
          </div>
        </nav>

        <div class="results-line" aria-live="polite">
          <span id="result-count">{commands.length}</span> commands visible
        </div>

        {
          categories.map((category) => (
            <section class="command-section" id={categoryIds.get(category)} data-section={category}>
              <div class="section-heading">
                <p class="section-kicker">category</p>
                <h2>{category}</h2>
                <a href={`#${categoryIds.get(category)}`}>#</a>
              </div>
              <div class="command-grid">
                {commands
                  .filter((command) => command.category === category)
                  .map((command) => {
                    const resp2Shape = getTypedReply(command.name, "resp2", command.resp2);
                    const resp3Shape = getTypedReply(command.name, "resp3", command.resp3);
                    const replyInspector = getReplyInspector(command.name, resp2Shape, resp3Shape, command.resp2, command.resp3);
                    const errorCases = getErrorCases(command);
                    return (
                    <article
                      class="command-card"
                      data-command-card
                      data-name={command.name.toLowerCase()}
                      data-category={command.category}
                      data-tags={command.tags.join(" ")}
                      data-search={`${command.name} ${command.category} ${command.signature} ${command.params.join(" ")} ${command.notes.join(" ")} ${errorCases.join(" ")} ${command.tags.join(" ")}`.toLowerCase()}
                    >
                      <header class="card-head">
                        <div>
                          <p class="command-category">{command.category}</p>
                          <h3>{command.name}</h3>
                        </div>
                        <div class="tag-bits">
                          {command.tags.slice(0, 3).map((tag) => (
                            <span>{tag}</span>
                          ))}
                        </div>
                      </header>

                      <div class="signature">
                        <span>$</span>
                        <code>{command.signature}</code>
                      </div>

                      <div class="card-columns">
                        <div>
                          <h4>Params</h4>
                          <ul>
                            {command.params.map((param) => (
                              <li>{param}</li>
                            ))}
                          </ul>
                        </div>
                        <div>
                          <h4>Reply</h4>
                          <div class="reply-panel">
                            <pre class="reply-code" data-resp2-shape={resp2Shape} data-resp3-shape={resp3Shape}>{resp2Shape}</pre>
                            <p class="reply-summary" data-resp2-note={command.resp2} data-resp3-note={command.resp3}>{command.resp2}</p>
                            <div class="reply-inspector" data-reply-inspector>
                              <div class="inspector-tabs" role="tablist" aria-label={`${command.name} reply views`}>
                                <button class="active" type="button" data-inspector-tab="tree">Tree</button>
                                <button type="button" data-inspector-tab="wire">Wire</button>
                                <button type="button" data-inspector-tab="decoded">Value</button>
                              </div>
                              <div class="inspector-toolbar">
                                <div class="scenario-tabs" data-scenario-tabs></div>
                                <div class="inspector-actions">
                                  <button type="button" data-raw-toggle>Raw</button>
                                  <button type="button" data-expand-all>Expand</button>
                                  <button type="button" data-collapse-all>Collapse</button>
                                </div>
                              </div>
                              <div
                                class="inspector-output"
                                data-active-view="tree"
                                data-active-scenario="success"
                                data-resp2-tree={replyInspector.resp2.tree}
                                data-resp2-wire={replyInspector.resp2.wire}
                                data-resp2-decoded={replyInspector.resp2.decoded}
                                data-resp3-tree={replyInspector.resp3.tree}
                                data-resp3-wire={replyInspector.resp3.wire}
                                data-resp3-decoded={replyInspector.resp3.decoded}
                              ></div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="notes">
                        <h4>Implementation notes</h4>
                        <ul>
                          {command.notes.map((note) => (
                            <li>{note}</li>
                          ))}
                        </ul>
                      </div>

                      <div class="error-cases">
                        <h4>Error cases</h4>
                        <ul>
                          {errorCases.map((errorCase) => (
                            <li>{errorCase}</li>
                          ))}
                        </ul>
                      </div>
                    </article>
                    );
                  })}
              </div>
            </section>
          ))
        }
      </main>
    </div>

    <script>
      const searchInput = document.querySelector("#command-search");
      const categoryFilter = document.querySelector("#category-filter");
      const resultCount = document.querySelector("#result-count");
      const modeLabels = document.querySelectorAll("[data-mode-label]");
      const modeInputs = document.querySelectorAll("input[name='resp-mode']");
      const tagButtons = document.querySelectorAll("[data-tag]");
      const cards = Array.from(document.querySelectorAll("[data-command-card]"));
      const sections = Array.from(document.querySelectorAll("[data-section]"));
      const pageBuildId = document.body.dataset.buildId;
      const versionUrl = document.body.dataset.versionUrl;
      let selectedTag = "all";
      let currentMode = "resp2";

      function inferBadge(text, fallback = "node") {
        const lower = text.toLowerCase();
        if (lower.includes("null")) return "null";
        if (lower.includes("array") || text.includes("[") || text.includes("*")) return "array";
        if (lower.includes("map") || text.includes("{") || text.includes("%")) return "map";
        if (lower.includes("push") || text.includes(">")) return "push";
        if (lower.includes("bulk")) return "bulk";
        if (lower.includes("blob")) return "blob";
        if (lower.includes("simple")) return "simple";
        if (lower.includes("integer") || lower.includes("int") || text.startsWith(":")) return "int";
        if (lower.includes("error")) return "error";
        if (lower.includes("string")) return "string";
        return fallback;
      }

      function clearNode(node) {
        while (node.firstChild) node.removeChild(node.firstChild);
      }

      function makeBadge(type) {
        const badge = document.createElement("span");
        badge.className = "inspector-badge";
        badge.dataset.badge = type;
        badge.textContent = type;
        return badge;
      }

      function makeLiteral(value) {
        const code = document.createElement("code");
        code.className = "inspector-literal";
        code.textContent = value;
        return code;
      }

      function renderNestedNode(node, { type = "node", open = true } = {}) {
        const children = node.children || [];
        if (!children.length) {
          const row = document.createElement("div");
          row.className = "inspector-leaf";
          row.append(makeBadge(node.type || type), document.createTextNode(" "), makeLiteral(node.label));
          if (node.description) {
            const description = document.createElement("span");
            description.className = "inspector-description";
            description.textContent = node.description;
            row.append(description);
          }
          return row;
        }

        const details = document.createElement("details");
        details.className = "inspector-node";
        details.open = node.open ?? open;
        const summary = document.createElement("summary");
        summary.append(makeBadge(node.type || type), document.createTextNode(" "), makeLiteral(node.label));
        if (node.description) {
          const description = document.createElement("span");
          description.className = "inspector-description";
          description.textContent = node.description;
          summary.append(description);
        }
        const branch = document.createElement("div");
        branch.className = "inspector-branch";
        children.forEach((child) => branch.append(renderNestedNode(child, { type, open: false })));
        details.append(summary, branch);
        return details;
      }

      function parseTreeLines(text) {
        const root = { label: "reply", type: "reply", open: true, children: [] };
        const stack = [{ indent: -1, node: root }];

        text
          .split("\n")
          .filter((line) => line.trim())
          .forEach((line, index) => {
            const label = line.replace(/^[\s│├└─]+/, "").trim();
            const prefix = line.match(/^[\s│├└─]*/)?.[0] || "";
            const indent = prefix.replace(/[├└─]/g, " ").length;
            const node = {
              label,
              type: index === 0 ? inferBadge(label, "reply") : inferBadge(label),
              open: indent <= 1,
              children: []
            };

            while (stack.length > 1 && indent <= stack[stack.length - 1].indent) stack.pop();
            stack[stack.length - 1].node.children.push(node);
            stack.push({ indent, node });
          });

        return root.children.length === 1 ? root.children[0] : root;
      }

      function getWireKind(line) {
        const prefix = line[0] || "";
        const map = {
          "*": "array",
          "$": "bulk",
          "+": "simple",
          "-": "error",
          ":": "int",
          "%": "map",
          "~": "set",
          ">": "push",
          "_": "null",
          "#": "bool",
          ",": "double"
        };
        return map[prefix] || "frame";
      }

      function parseWireScenario(raw) {
        const frames = raw
          .split("\\r\\n")
          .flatMap((line) => line.split("\n"))
          .map((line) => line.trim())
          .filter(Boolean);

        return frames.map((line) => ({
          label: line,
          type: getWireKind(line),
          description: line.startsWith("#") ? "scenario marker" : undefined
        }));
      }

      function splitScenarioText(text, defaultName = "success") {
        const scenarios = [];
        let current = { name: defaultName, text: "" };
        const normalizeScenarioName = (name) => {
          const lower = name.trim().toLowerCase();
          if (lower.includes("timeout")) return "timeout";
          if (lower.includes("watch")) return "watch abort";
          if (lower.includes("null")) return "null";
          return lower.replace(/\s+/g, "-");
        };

        text.split(/\n#\s*/).forEach((chunk, index) => {
          if (index === 0) {
            current.text = chunk.trim();
            scenarios.push(current);
            return;
          }

          const [nameLine, ...rest] = chunk.split("\n");
          scenarios.push({ name: normalizeScenarioName(nameLine), text: rest.join("\n").trim() });
        });

        return scenarios.filter((scenario) => scenario.text);
      }

      function parseValueScenarios(text) {
        try {
          const parsed = JSON.parse(text);
          if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
            const keys = Object.keys(parsed);
            const scenarioKeys = keys.filter((key) => ["success", "timeout", "watchAbort", "empty", "nil", "null"].includes(key));
            if (scenarioKeys.length > 1) {
              return scenarioKeys.map((key) => ({ name: key.replace(/([A-Z])/g, " $1").toLowerCase(), value: parsed[key] }));
            }
          }
          return [{ name: "value", value: parsed }];
        } catch {
          return [{ name: "value", value: text }];
        }
      }

      function renderValueNode(value, label = "value") {
        if (Array.isArray(value)) {
          return renderNestedNode({
            label: `${label}: array(${value.length})`,
            type: "array",
            open: true,
            children: value.map((item, index) => ({ label: `[${index}]`, type: inferBadge(String(item)), children: [valueNodeShape(item)] }))
          });
        }

        if (value && typeof value === "object") {
          return renderNestedNode({
            label: `${label}: object`,
            type: "map",
            open: true,
            children: Object.entries(value).map(([key, item]) => ({ label: key, type: inferBadge(String(item)), children: [valueNodeShape(item)] }))
          });
        }

        return renderNestedNode(valueNodeShape(value, label));
      }

      function valueNodeShape(value, label = "value") {
        if (Array.isArray(value)) {
          return {
            label: `${label}: array(${value.length})`,
            type: "array",
            children: value.map((item, index) => valueNodeShape(item, `[${index}]`))
          };
        }
        if (value && typeof value === "object") {
          return {
            label: `${label}: object`,
            type: "map",
            children: Object.entries(value).map(([key, item]) => valueNodeShape(item, key))
          };
        }
        return { label: `${label}: ${value === null ? "null" : JSON.stringify(value)}`, type: value === null ? "null" : typeof value };
      }

      function setScenarioTabs(inspector, scenarios, activeName, onSelect) {
        const tabs = inspector.querySelector("[data-scenario-tabs]");
        clearNode(tabs);
        tabs.hidden = scenarios.length <= 1;
        scenarios.forEach((scenario) => {
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = scenario.name;
          button.classList.toggle("active", scenario.name === activeName);
          button.addEventListener("click", () => onSelect(scenario.name));
          tabs.append(button);
        });
      }

      function renderTreeView(output, text) {
        output.append(renderNestedNode(parseTreeLines(text)));
      }

      function renderWireView(inspector, output, text) {
        const rawMode = inspector.dataset.rawMode === "true";
        const scenarios = splitScenarioText(text);
        const activeScenario = scenarios.some((scenario) => scenario.name === output.dataset.activeScenario) ? output.dataset.activeScenario : scenarios[0]?.name;
        output.dataset.activeScenario = activeScenario || "success";
        setScenarioTabs(inspector, scenarios, output.dataset.activeScenario, (name) => {
          output.dataset.activeScenario = name;
          updateInspectorOutput(output);
        });

        const scenario = scenarios.find((item) => item.name === output.dataset.activeScenario) || scenarios[0];
        if (!scenario) return;

        if (rawMode) {
          const pre = document.createElement("pre");
          pre.className = "inspector-raw";
          pre.textContent = scenario.text;
          output.append(pre);
          return;
        }

        parseWireScenario(scenario.text).forEach((frame) => output.append(renderNestedNode(frame, { type: "frame", open: false })));
      }

      function renderValueView(inspector, output, text) {
        const scenarios = parseValueScenarios(text);
        const activeScenario = scenarios.some((scenario) => scenario.name === output.dataset.activeScenario) ? output.dataset.activeScenario : scenarios[0]?.name;
        output.dataset.activeScenario = activeScenario || "value";
        setScenarioTabs(inspector, scenarios, output.dataset.activeScenario, (name) => {
          output.dataset.activeScenario = name;
          updateInspectorOutput(output);
        });

        const scenario = scenarios.find((item) => item.name === output.dataset.activeScenario) || scenarios[0];
        if (!scenario) return;
        output.append(renderValueNode(scenario.value, scenario.name));
      }

      function updateInspectorOutput(output) {
        const inspector = output.closest("[data-reply-inspector]");
        const view = output.dataset.activeView || "tree";
        const text = output.dataset[`${currentMode}${view[0].toUpperCase()}${view.slice(1)}`] || "";
        clearNode(output);
        inspector.querySelector("[data-raw-toggle]").hidden = view !== "wire";
        inspector.querySelector("[data-scenario-tabs]").hidden = true;

        if (view === "tree") renderTreeView(output, text);
        if (view === "wire") renderWireView(inspector, output, text);
        if (view === "decoded") renderValueView(inspector, output, text);
      }

      function updateMode(mode) {
        currentMode = mode;
        const label = mode.toUpperCase();
        modeLabels.forEach((node) => {
          node.textContent = label;
        });
        document.querySelectorAll("[data-resp2-shape]").forEach((node) => {
          node.textContent = node.dataset[`${mode}Shape`] || "";
        });
        document.querySelectorAll("[data-resp2-note]").forEach((node) => {
          node.textContent = node.dataset[`${mode}Note`] || "";
        });
        document.querySelectorAll("[data-active-view]").forEach(updateInspectorOutput);
        document.documentElement.dataset.respMode = mode;
      }

      function applyFilters() {
        const query = searchInput.value.trim().toLowerCase();
        const category = categoryFilter.value;
        let visible = 0;

        cards.forEach((card) => {
          const matchesQuery = !query || card.dataset.search.includes(query);
          const matchesCategory = category === "all" || card.dataset.category === category;
          const tags = card.dataset.tags.split(" ");
          const matchesTag = selectedTag === "all" || tags.includes(selectedTag);
          const show = matchesQuery && matchesCategory && matchesTag;
          card.hidden = !show;
          if (show) visible += 1;
        });

        sections.forEach((section) => {
          const visibleCards = section.querySelectorAll("[data-command-card]:not([hidden])").length;
          section.hidden = visibleCards === 0;
        });

        resultCount.textContent = String(visible);
      }

      modeInputs.forEach((input) => {
        input.addEventListener("change", () => updateMode(input.value));
      });

      tagButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectedTag = button.dataset.tag;
          tagButtons.forEach((tag) => tag.classList.toggle("active", tag === button));
          applyFilters();
        });
      });

      document.querySelectorAll("[data-reply-inspector]").forEach((inspector) => {
        const output = inspector.querySelector("[data-active-view]");
        const rawToggle = inspector.querySelector("[data-raw-toggle]");
        const expandAll = inspector.querySelector("[data-expand-all]");
        const collapseAll = inspector.querySelector("[data-collapse-all]");

        inspector.querySelectorAll("[data-inspector-tab]").forEach((button) => {
          button.addEventListener("click", () => {
            output.dataset.activeView = button.dataset.inspectorTab;
            output.dataset.activeScenario = button.dataset.inspectorTab === "wire" ? "success" : "value";
            inspector.querySelectorAll("[data-inspector-tab]").forEach((tab) => {
              tab.classList.toggle("active", tab === button);
            });
            updateInspectorOutput(output);
          });
        });

        rawToggle.addEventListener("click", () => {
          inspector.dataset.rawMode = inspector.dataset.rawMode === "true" ? "false" : "true";
          rawToggle.classList.toggle("active", inspector.dataset.rawMode === "true");
          updateInspectorOutput(output);
        });

        expandAll.addEventListener("click", () => {
          output.querySelectorAll("details").forEach((details) => {
            details.open = true;
          });
        });

        collapseAll.addEventListener("click", () => {
          output.querySelectorAll("details").forEach((details) => {
            details.open = false;
          });
        });
      });

      searchInput.addEventListener("input", applyFilters);
      categoryFilter.addEventListener("change", applyFilters);

      async function refreshIfStaleBuild() {
        if (!pageBuildId || pageBuildId === "local" || !versionUrl) return;

        try {
          const url = new URL(versionUrl, window.location.origin);
          url.searchParams.set("_", String(Date.now()));
          const response = await fetch(url, { cache: "no-store" });
          if (!response.ok) return;

          const latest = await response.json();
          if (!latest.buildId || latest.buildId === pageBuildId) return;

          const reloadKey = `redis-cheatsheet-reloaded-${latest.buildId}`;
          if (sessionStorage.getItem(reloadKey)) return;

          sessionStorage.setItem(reloadKey, "1");
          const nextUrl = new URL(window.location.href);
          nextUrl.searchParams.set("_v", latest.buildId);
          window.location.replace(nextUrl);
        } catch {
          // Cache refresh is best-effort; the reference remains usable if it fails.
        }
      }

      updateMode("resp2");
      applyFilters();
      refreshIfStaleBuild();
    </script>
  </body>
</html>
